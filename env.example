# ===========================================
# 認証（ステップ1で使用）
# ===========================================
AUTH_USERNAME=aracode
AUTH_PASSWORD=your-password-here
# セッション署名用の秘密鍵（32文字以上のランダム文字列を推奨）
AUTH_SECRET=your-long-random-secret-key-here

# ===========================================
# Google Sheets API（ステップ2以降で使用）
# ===========================================
# スプレッドシートURLの /d/ と /edit の間の文字列
GOOGLE_SHEETS_SPREADSHEET_ID=
# サービスアカウントの client_email（xxx@xxx.iam.gserviceaccount.com）
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# JSONキーの private_key（改行は \n でエスケープして1行で記載）
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Google Cloud Storage（Phase2 画像保存で使用）
GCS_BUCKET_NAME=
# 任意: 自動判定される場合は省略可能
GCS_PROJECT_ID=

# ===========================================
# Claude API（ステップ5で使用）
# ===========================================
ANTHROPIC_API_KEY=
# 任意: 使用モデル（デフォルト: claude-sonnet-4-20250514）
ANTHROPIC_MODEL=
